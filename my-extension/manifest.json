{
  "manifest_version": 3,
  "name": "ConsentOS",
  "version": "1.0",
  "description": "Summarizes consent popups with AI",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}